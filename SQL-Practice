import pytest
from sqlalchemy import create_engine
from config.db_config import DB_URL

@pytest.fixture(scope="session")
def db_engine():
    engine = create_engine(DB_URL)
    yield engine
    engine.dispose()

@pytest.fixture
def db_connection(db_engine):
    conn = db_engine.connect()
    yield conn
    conn.close()

